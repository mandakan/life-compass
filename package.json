    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.12",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
