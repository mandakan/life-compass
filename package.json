    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.0.4",
