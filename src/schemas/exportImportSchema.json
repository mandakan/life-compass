{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Life Compass Export/Import Schema",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "exportTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string"
        }
      },
      "required": ["exportTimestamp", "version"],
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "properties": {
        "userSettings": {
          "type": "object",
          "properties": {
            "language": {
              "type": "string"
            },
            "theme": {
              "type": "string",
              "enum": ["light", "dark"]
            }
          },
          "required": ["language", "theme"],
          "additionalProperties": true
        },
        "lifeAreas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "importance": {
                "type": "number"
              },
              "satisfaction": {
                "type": "number"
              },
              "details": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "description",
              "importance",
              "satisfaction",
              "details"
            ],
            "additionalProperties": true
          }
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "areaId": { "type": "string" },
              "title": { "type": "string" },
              "createdAt": { "type": "string" },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "text": { "type": "string" },
                    "done": { "type": "boolean" }
                  },
                  "required": ["id", "text", "done"],
                  "additionalProperties": true
                }
              }
            },
            "required": ["id", "areaId", "title", "createdAt", "steps"],
            "additionalProperties": true
          }
        },
        "behavioralExperiments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "areaId": { "type": "string" },
              "title": { "type": "string" },
              "createdAt": { "type": "string" },
              "outcome": { "type": "string" },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "text": { "type": "string" },
                    "done": { "type": "boolean" }
                  },
                  "required": ["id", "text", "done"],
                  "additionalProperties": true
                }
              }
            },
            "required": ["id", "title", "createdAt", "steps"],
            "additionalProperties": true
          }
        },
        "thoughtRecords": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "areaId": { "type": "string" },
              "situation": { "type": "string" },
              "thought": { "type": "string" },
              "feeling": { "type": "string" },
              "feelingBefore": { "type": "number" },
              "supports": { "type": "string" },
              "widerView": { "type": "string" },
              "kinderView": { "type": "string" },
              "feelingAfter": { "type": "number" },
              "createdAt": { "type": "string" }
            },
            "required": [
              "id",
              "situation",
              "thought",
              "feeling",
              "supports",
              "widerView",
              "kinderView",
              "createdAt"
            ],
            "additionalProperties": true
          }
        },
        "problemSolvings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "areaId": { "type": "string" },
              "problem": { "type": "string" },
              "chosenOptionId": { "type": "string" },
              "outcome": { "type": "string" },
              "createdAt": { "type": "string" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "text": { "type": "string" },
                    "pros": { "type": "string" },
                    "cons": { "type": "string" }
                  },
                  "required": ["id", "text", "pros", "cons"],
                  "additionalProperties": true
                }
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "text": { "type": "string" },
                    "done": { "type": "boolean" }
                  },
                  "required": ["id", "text", "done"],
                  "additionalProperties": true
                }
              }
            },
            "required": [
              "id",
              "problem",
              "options",
              "steps",
              "outcome",
              "createdAt"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": ["userSettings", "lifeAreas", "history"],
      "additionalProperties": false
    }
  },
  "required": ["metadata", "data"],
  "additionalProperties": false
}
